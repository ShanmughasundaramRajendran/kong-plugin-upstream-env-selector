meta {
  name: Default Header Overrides Others
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/orders
  body: none
  auth: none
}

params:query {
  env: prod
  resource_env: dev
}

headers {
  Accept: application/json
  X-Upstream-Env: qa
  X-Client-Env: dev
  X-Resource-Env: prod
  Authorization: Bearer {{jwt_neutral_client}}
}
