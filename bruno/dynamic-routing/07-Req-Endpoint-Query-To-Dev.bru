meta {
  name: 07-Req-SNI To Dev
  type: http
  seq: 7
}

get {
  url: {{sni_access_base_url}}/private/684130/developer-platform/gateway/clients
  body: none
  auth: none
}

headers {
  Accept: application/json
  Host: access-sni-dev.local
  Authorization: Bearer {{jwt_neutral_client}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("routes to dev", function() {
    const body = JSON.parse(res.getBody());
    expect(body.environment.ECHO_RESPONSE).to.equal("dev");
  });
}

docs {
  SNI selector routes request when TLS SNI matches an upstream key.
  Prerequisite: host entry for access-sni-dev.local and TLS verification disabled in Bruno.
  Expected backend: dev.
}
